# ---- NextAuth ----
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Needed when running behind a proxy (e.g. production) so NextAuth trusts the forwarded host.
# Safe to leave unset in local dev.
AUTH_TRUST_HOST=true

# Encrypts each user's GitHub OAuth access_token at rest in the users table.
# Generate: openssl rand -base64 32 (must decode to exactly 32 bytes).
# Losing this key invalidates all stored tokens — users will have to sign in again.
TOKEN_ENCRYPTION_KEY=

# ---- GitHub OAuth ----
# Create one OAuth App per environment at https://github.com/settings/developers.
# Two NextAuth providers (github-admin / github-viewer) share the same app, so the
# Authorization callback URL must be the PREFIX (no provider suffix) — it matches both
# .../callback/github-admin and .../callback/github-viewer.
#   Dev:  Authorization callback URL = http://localhost:3003/api/auth/callback
#   Prod: Authorization callback URL = https://<your-domain>/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated numeric GitHub user IDs allowed to sign in as admin (full access).
# Find yours: curl -s https://api.github.com/users/<login> | jq .id
ADMIN_GITHUB_IDS=

# Comma-separated GitHub user IDs allowed to sign in as viewer (read-only).
# Empty disables the viewer flow; admins implicitly have viewer access too.
VIEWER_GITHUB_IDS=

# ---- LLM provider keys ----
ANTHROPIC_API_KEY=
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ---- GitHub CLI fallback ----
# Optional. When a repo has a stored owner (assigned at signup or via the UI), janitor
# uses that user's OAuth token for gh/git operations. GH_TOKEN is only consulted as a
# fallback for repos with no owner assigned. Safe to leave unset once all repos have owners.
GH_TOKEN=

# ---- Database ----
DATABASE_URL=postgres://localhost:5432/janitor
